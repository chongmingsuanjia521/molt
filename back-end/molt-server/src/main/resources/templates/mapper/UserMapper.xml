<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="asia.wjm.mapper.UserMapper">

    <insert id="insert">
        INSERT INTO user
            (username, password, email, name, sex, age, status, phone, avatar, create_time, school, level, points, bio, birthday, update_time, last_login_time)
        VALUES (
            #{username}, #{password}, #{email}, #{name}, #{sex}, #{age}, #{status}, #{phone}, #{avatar}, #{createTime}, #{school}, #{level}, #{points}, #{bio}, #{birthday}, #{updateTime}, #{lastLoginTime}
        )
    </insert>
    <update id="update">
        UPDATE user
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="email != null and email != ''">
                email = #{email},
            </if>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="sex != null and sex != ''">
                sex = #{sex},
            </if>
            <if test="age != null">
                age = #{age},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="phone != null and phone != ''">
                phone = #{phone},
            </if>
            <if test="avatar != null and avatar != ''">
                avatar = #{avatar},
            </if>
            <if test="school != null and school != ''">
                school = #{school},
            </if>
            <if test="level != null">
                level = #{level},
            </if>
            <if test="points != null">
                points = #{points},
            </if>
            <if test="bio != null and bio != ''">
                bio = #{bio},
            </if>
            <if test="birthday != null">
                birthday = #{birthday},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="lastLoginTime != null">
                last_login_time = #{lastLoginTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    <delete id="deleteBatch">
        DELETE FROM user WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="pageQuery" resultType="asia.wjm.entity.User">
        SELECT * FROM user
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="sex != null and sex != ''">
                 AND sex = #{sex}
            </if>
                 <if test="createTime!=null and createTime!=''">
                 AND #{createTime} &gt;= create_time
                 AND #{createTime} &lt;= end_time
                 </if>
        </where>
        ORDER BY create_time DESC
    </select>
    <select id="getByIds" resultType="asia.wjm.entity.User">
        SELECT * FROM user WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{ids}
        </foreach>
    </select>


</mapper>
